{
  "hooks": {
    "Stop": [
      {
        "id": "cast-journal-session-end",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cast-journal-session-end.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "id": "cast-session-start-journal",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cast-session-start-journal.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
